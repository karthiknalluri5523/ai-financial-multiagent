# Copy to .env and fill in.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Postgres + pgvector
DATABASE_URL=postgresql+psycopg://app:app@db:5432/finai

# Optional observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

APP_LOG_LEVEL=INFO
APP_MAX_CRITIC_LOOPS=2
